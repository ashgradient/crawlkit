// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ AUTH (NextAuth) ============

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed, for credentials login
  role          UserRole  @default(CONSUMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   OrgMember[]
  checkIns      CheckIn[]
  passport      Passport?
  ownedOrg      Organization? @relation("OrgOwner")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  ROUTE_MANAGER
  BUSINESS_OWNER
  CONSUMER
}

// ============ ORGANIZATION ============

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  city        String
  plan        PlanTier @default(STARTER)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId     String   @unique
  owner       User     @relation("OrgOwner", fields: [ownerId], references: [id])
  members     OrgMember[]
  routes      Route[]
  businesses  Business[]
}

enum PlanTier {
  FREE
  BUSINESS
  STARTER
  GROWTH
  ENTERPRISE
}

model OrgMember {
  id     String   @id @default(cuid())
  role   OrgRole  @default(VIEWER)
  userId String
  orgId  String

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

enum OrgRole {
  ADMIN
  ROUTE_MANAGER
  BUSINESS_OWNER
  VIEWER
}

// ============ BUSINESSES ============

model Business {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  address     String
  lat         Float
  lng         Float
  category    String
  imageUrl    String?
  website     String?
  phone       String?
  orgId       String

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stops       RouteStop[]
  qrCodes     QRCode[]
  checkIns    CheckIn[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ============ ROUTES ============

model Route {
  id          String      @id @default(cuid())
  name        String
  slug        String
  description String?     @db.Text
  city        String
  imageUrl    String?
  isPublished Boolean     @default(false)
  totalStops  Int         @default(0)
  estimatedMinutes Int    @default(60)
  orgId       String

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stops       RouteStop[]
  checkIns    CheckIn[]
  passportStamps PassportStamp[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([orgId, slug])
}

model RouteStop {
  id         String   @id @default(cuid())
  order      Int
  routeId    String
  businessId String

  route      Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  qrCodes    QRCode[]

  @@unique([routeId, order])
}

// ============ QR CODES & CHECK-INS ============

model QRCode {
  id         String   @id @default(cuid())
  token      String   @unique @default(cuid())
  businessId String
  stopId     String?

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stop       RouteStop? @relation(fields: [stopId], references: [id])
  checkIns   CheckIn[]
  createdAt  DateTime   @default(now())
}

model CheckIn {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  routeId    String?
  qrCodeId   String?
  lat        Float?
  lng        Float?
  method     CheckInMethod @default(QR)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  route      Route?   @relation(fields: [routeId], references: [id])
  qrCode     QRCode?  @relation(fields: [qrCodeId], references: [id])

  @@unique([userId, businessId, routeId]) // anti-fraud: 1 check-in per user per stop per route
}

enum CheckInMethod {
  QR
  GPS
  MANUAL
}

// ============ DIGITAL PASSPORT ============

model Passport {
  id        String   @id @default(cuid())
  userId    String   @unique
  level     Int      @default(1)
  xp        Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stamps    PassportStamp[]
}

model PassportStamp {
  id        String   @id @default(cuid())
  passportId String
  routeId   String
  completedAt DateTime @default(now())
  stopsCompleted Int

  passport  Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)
  route     Route    @relation(fields: [routeId], references: [id])

  @@unique([passportId, routeId])
}
